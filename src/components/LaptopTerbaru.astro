---
const products = [
  {
    name: "Hp Probook 635 G7 Ryzen 5",
    image: "/img/Hp Probook 635 G7 Ryzen 5.jpg",
    wa: "https://wa.me/6281364087823?text=Halo,%20saya%20tanya%20stok%20Hp%20Probook%20635%20G7%20Ryzen%205",
  },
  {
    name: "Nec VersaPro VB-9 Core i5 Gen 10",
    image: "/img/Nec VersaPro VB-9 Core i5 Gen 10.jpg",
    wa: "https://wa.me/6281364087823?text=Halo,%20saya%20tanya%20stok%20Nec%20VersaPro%20VB-9%20Core5%20Gen%20Gen%2010",
  },
  {
    name: "Fujitsu LifeBook U938 Core i5 Gen 8",
    image: "/img/Fujitsu LifeBook U938 Core i5 Gen 8.jpg",
    wa: "https://wa.me/6281364087823?text=Halo,%20saya%20tanya%20stok%20Fujitsu%20LifeBook%20U938%20Core5%20Gen%208",
  },
  {
    name: "Dell Latitude 3310 Core i3 Gen 8",
    image: "/img/Dell Latitude 3310 Core i3 Gen 8.jpg",
    wa: "https://wa.me/6281364087823?text=Halo,%20saya%20tanya%20stok%20Dell%20Latitude%203310%20Core3%20Gen%208",
  },

  // produk lainnya...
];

const initialProducts = products.slice(0, 8);
---

<!-- Laptop Terbaru Section -->
<section id="laptop-terbaru" class="py-20 px-4 bg-white">
  <div class="container mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-800 mb-4">
        Laptop Terbaru
      </h2>
      <p class="text-xl text-gray-600">
        Stok terbaru yang baru saja masuk di toko kami
      </p>
    </div>

    <div class="grid md:grid-cols-4 gap-6" id="product-grid">
      {
        initialProducts.map((product) => (
          <div class="bg-white rounded-xl overflow-hidden shadow-md border border-gray-100 hover:shadow-xl transition">
            <img
              src={product.image}
              alt={product.name}
              class="w-full aspect-square object-cover"
            />

            <div class="p-5 text-center">
              <h3 class="font-bold text-gray-800 mb-4">{product.name}</h3>

              <a
                href={product.wa}
                class="inline-block w-full bg-primary text-white py-2 rounded-lg font-semibold hover:opacity-90 transition"
                target="_blank"
              >
                Detail Produk
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
